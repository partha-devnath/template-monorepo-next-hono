# Database
DATABASE_URL=postgres://template:template@localhost:5432/template

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# Server
CLIENT_URL=http://localhost:3000
PORT=3001
LOG_LEVEL=info

# Email (console | mailpit | resend)
EMAIL_PROVIDER=mailpit
# MAILPIT_HOST=localhost
# MAILPIT_SMTP_PORT=1025
EMAIL_FROM=noreply@localhost
# RESEND_API_KEY=

# Content Security Policy (override default if needed)
# CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' https: data:; connect-src 'self' https:; frame-ancestors 'none'

# S3 Storage (MinIO local, AWS S3 / GCS / R2 in production)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=template
# S3_BASE_URL=
